# .gitignore
# .dvc/config (the remote name/URL) and .dvcignore are meant to be
# committed and shared; DVC's own auto-generated .dvc/.gitignore already
# excludes config.local, cache/, and tmp/ (the machine-specific/
# credential/generated parts).
.git/

# Python Environment
__pycache__/
*.pyc

# Data and Models (Keep local size low)
data/raw/*
data/processed/*
data/interim/*
models/*

# OS/IDE junk
.vscode/
.idea/
/metrics.json
